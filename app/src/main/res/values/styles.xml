<resources>
    
    <style name="ToolbarPopupTheme" parent="ThemeOverlay.AppCompat.Dark">
        <item name="android:popupBackground">#172033</item>
        <item name="android:textColorPrimary">#F8FAFC</item>
        <item name="android:textColorSecondary">#C7D2FE</item>
    </style>

    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#7C3AED</item>
        <item name="colorPrimaryVariant">#6D28D9</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <item name="colorSecondary">#60A5FA</item>
        <item name="colorSecondaryVariant">#3B82F6</item>
        <item name="colorOnSecondary">#FFFFFF</item>
  
        <item name="android:statusBarColor">#0B1020</item>
        <item name="android:navigationBarColor">#0B1020</item>
        <item name="materialAlertDialogTheme">@style/RoundedDialogTheme</item>
    </style>

    <style name="RoundedDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="shapeAppearanceMediumComponent">@style/RoundedShapeAppearance</item>
        <item name="backgroundTint">#F8FAFC</item>
        <item name="colorSurface">#F8FAFC</item>
        <item name="materialAlertDialogTitleTextStyle">@style/DialogTitleText</item>
        <item name="materialAlertDialogBodyTextStyle">@style/DialogBodyText</item>
        <item name="buttonBarPositiveButtonStyle">@style/DialogButtonText</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogButtonText</item>
        <item name="buttonBarNeutralButtonStyle">@style/DialogButtonText</item>
    </style>

    <style name="RoundedShapeAppearance" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="DialogTitleText" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">#0F172A</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DialogBodyText" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">#334155</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="DialogButtonText" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#2563EB</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>
